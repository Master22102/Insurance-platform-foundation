Computed balance function:
CREATE OR REPLACE FUNCTION get_scan_credits_balance(p_trip_id uuid)RETURNS integer LANGUAGE sql STABLE SECURITY DEFINER AS $$  SELECT COALESCE(SUM(credits_delta), 0)::integer  FROM scan_credit_ledger WHERE trip_id = p_trip_id;$$;

